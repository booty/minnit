<h1>Log in</h1>

<%= form_with url: login_path do |f| %>
  <div>
    <%= f.label :email, "Email" %>
    <%= f.email_field :email %>
  </div>
  <div>
    <%= f.label :password, "Password" %>
    <%= f.password_field :password %>
  </div>
  <%= f.submit "Log in" %>
<% end %>

<p>New here? <%= link_to "Sign up", signup_path %></p>
